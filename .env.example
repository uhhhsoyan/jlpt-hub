# Copy to .env.local and fill in.

# Claude API key — console.anthropic.com → API keys.
# Powers sentence generation. (Separate from any claude.ai subscription.)
ANTHROPIC_API_KEY=

# Neon Postgres connection string — Vercel → Storage → Neon, or neon.tech.
# Needed to save/browse sentences; generation works without it.
DATABASE_URL=

# Vercel Blob read/write token — Vercel dashboard → project jlpt-hub → Storage →
# Create → Blob, then copy the token it gives you. Powers cloud storage for practice
# photos, sprint audio, and mined clips (so they survive a deploy, since public/ writes
# don't). Without it, media falls back to local public/ paths — fine for `npm run dev`,
# but won't work once deployed.
BLOB_READ_WRITE_TOKEN=

# WaniKani personal access token — wanikani.com/settings/personal_access_tokens.
# Powers the "Sync WaniKani" progress import; read-only default permissions are enough.
WANIKANI_TOKEN=

# Listening Mine (local only). Path to a whisper.cpp ggml model, e.g.
# ~/models/ggml-large-v3-turbo.bin. See SETUP.md for install.
WHISPER_MODEL=
# Optional: override the whisper CLI (default: whisper-cli).
WHISPER_CLI=
